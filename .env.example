# Firebase Configuration (replaces Supabase)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
# JSON-encoded service account credentials (used by Node.js server with firebase-admin)
# Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service_account.json'
FIREBASE_SERVICE_ACCOUNT_JSON=test

# Discord Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-channel-id
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_GUILD_ID=your-discord-guild-id

# Twilio Configuration (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid
