# ─────────────────────────────────────────────
# Firebase Configuration
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com

# Server-side Admin SDK (Node.js) — JSON-encoded service account
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Python services — path to the Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/services/config/firebase_service_account.json

# ─────────────────────────────────────────────
# Discord Configuration
# ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-channel-id
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_GUILD_ID=your-discord-guild-id

# ─────────────────────────────────────────────
# Twilio Configuration (SMS)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid

# ─────────────────────────────────────────────
# bCourses (Canvas LMS) Integration
# Create a developer key at:
# https://bcourses.berkeley.edu (Admin > Developer Keys)
# Set the redirect URI to: https://your-domain/api/canvas/callback
# ─────────────────────────────────────────────
CANVAS_CLIENT_ID=your-canvas-developer-key-id
CANVAS_CLIENT_SECRET=your-canvas-developer-key-secret
CANVAS_REDIRECT_URI=http://localhost:3000/api/canvas/callback
CANVAS_DEFAULT_DOMAIN=bcourses.berkeley.edu

# ─────────────────────────────────────────────
# Admin Dashboard
# Comma-separated Google account emails allowed
# to access /admin.html
# ─────────────────────────────────────────────
ADMIN_EMAILS=admin@berkeley.edu,instructor@berkeley.edu
